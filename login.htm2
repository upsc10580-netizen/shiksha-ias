<!DOCTYPE html>
<html>
<head>
<title>Student Login - SHIKSHA I.A.S</title>
<style>
body{
font-family:Arial;
background:#f4f4f4;
text-align:center;
margin:0;
}

.login-box{
background:white;
width:300px;
margin:100px auto;
padding:30px;
border-radius:10px;
box-shadow:0 0 10px gray;
}

input{
width:90%;
padding:10px;
margin:10px 0;
}

button{
padding:10px 20px;
background:#002147;
color:white;
border:none;
cursor:pointer;
}
</style>
</head>

<body>

<div class="login-box">
<h2>Student Login</h2>

<input type="text" id="username" placeholder="Enter Username"><br>
<input type="password" id="password" placeholder="Enter Password"><br>

<button onclick="login()">Login</button>

<p id="result"></p>
</div>

